# Update OpenWebUI Docker container on Windows

$containerName = "open-webui"
$image = "ghcr.io/open-webui/open-webui:main"
$volume = "open-webui"

Write-Host "Pulling latest OpenWebUI image..."
docker pull $image

Write-Host "Checking for existing container..."
$existing = docker ps -a --filter "name=$containerName" --format "{{.Names}}"

if ($existing -eq $containerName) {
    Write-Host "Stopping existing container..."
    docker stop $containerName | Out-Null

    Write-Host "Removing existing container..."
    docker rm $containerName | Out-Null
}

Write-Host "Starting updated OpenWebUI container..."
docker run -d `
  -p 3000:8080 `
  -v ${volume}:/app/backend/data `
  --name $containerName `
  --restart always `
  $image

Write-Host "Update complete."
Write-Host "Open WebUI at: http://localhost:3000"
docker ps --filter "name=$containerName"
