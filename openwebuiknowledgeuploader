#requires -Version 7.0
Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

<#
    OpenWebUI Knowledge Sync - PS7 Resilient Edition
    - Fixed: Strict Mode compatibility for $stream and JSON parsing
    - Fixed: PS7 DateTime auto-conversion during signature checks
    - Feature: Universal Whitelist & Junk Mover
    - Feature: Minimum file size filter to prevent empty-file crashes
    - Feature: Master Try/Catch resilience (prevents complete script halts)
    - Feature: Dedicated sync-errors.txt log for easy troubleshooting
    - Feature: Empty directory tree cleanup during processing
    - Patch: Replaced invalid continue statement with explicit :FileLoop label
    - Patch: Atomic state writes to prevent corruption on power loss
    - Patch: Mandatory SHA256 hashing and file deletion upon successful sync
    - Optimization: Replaced .NET HttpClient with Invoke-RestMethod
#>

# ------------------------------
# CONFIGURE HERE
# ------------------------------
$OpenWebUIBaseUrl     = "http://localhost:3000"
$OpenWebUIToken       = "sk-"
$KnowledgeId          = ""
$RootPath             = "C:\AI\"
$LogRoot              = "C:\AI\log"
$JunkPath             = "C:\AI\Junk"

# Filters
$MinSizeBytes         = 100 # Skips files smaller than this to prevent backend RAG crashes

# Upload / polling behavior
$MaxRetries           = 3
$RetryDelaySeconds    = 10
$PollIntervalSeconds  = 2
$ProcessTimeoutSeconds = 1800

# File selection - Universal Whitelist
$IncludeHiddenFiles   = $false
$IncludeExtensions    = @(
    ".pdf", ".docx", ".doc", ".rtf", ".odt", ".txt", ".epub", ".pages",
    ".csv", ".tsv", ".xlsx", ".xls", ".ods", ".json", ".jsonl", ".toml",
    ".html", ".htm", ".xhtml", ".md", ".mdx", ".xml", ".tex", ".asciidoc", ".adoc",
    ".ps1", ".psm1", ".psd1", ".bat", ".cmd", ".vbs", ".sh", ".bash", ".py", ".js", ".sql", ".vba", ".lua", ".pl", ".groovy",
    ".cs", ".c", ".cpp", ".h", ".hpp", ".go", ".rs", ".rb", ".php", ".css", ".scss", ".java", ".ts", ".tsx", ".jsx", ".kt", ".swift", ".scala",
    ".config", ".ini", ".yaml", ".yml", ".log", ".properties", ".reg", ".sln", ".csproj", ".iloprj", ".editorconfig", ".gitattributes", ".gitignore", ".props", ".targets", ".plist", ".resx", ".strings", ".eml",
    ".pptx", ".ppt", ".odp"
) 
$ExcludeExtensions    = @()

# ------------------------------
# DERIVED PATHS
# ------------------------------
$OpenWebUIBaseUrl = $OpenWebUIBaseUrl.TrimEnd('/')
$null = New-Item -ItemType Directory -Path $LogRoot -Force
if (-not (Test-Path -LiteralPath $JunkPath)) {
    $null = New-Item -ItemType Directory -Path $JunkPath -Force
}

$StatePath      = Join-Path $LogRoot "state.json"
$JsonlLogPath   = Join-Path $LogRoot "sync-log.jsonl"
$SummaryCsvPath = Join-Path $LogRoot "sync-summary.csv"
$ErrorLogPath   = Join-Path $LogRoot "sync-errors.txt"

$ApiHeaders = @{
    "Authorization" = "Bearer $OpenWebUIToken"
    "Accept"        = "application/json"
}

# ------------------------------
# HELPERS
# ------------------------------

function Remove-EmptyDirectoryTree {
    param(
        [Parameter(Mandatory)]
        [string]$DirectoryPath,

        [Parameter(Mandatory)]
        [string]$RootLimitPath
    )

    $currentDir = [System.IO.Path]::GetFullPath($DirectoryPath)
    $rootLimit = [System.IO.Path]::GetFullPath($RootLimitPath).TrimEnd('\', '/')

    while ($currentDir.Length -gt $rootLimit.Length -and (Test-Path -LiteralPath $currentDir)) {
        $items = Get-ChildItem -LiteralPath $currentDir -Force
        if ($items.Count -eq 0) {
            try {
                Remove-Item -LiteralPath $currentDir -Force
                $currentDir = Split-Path -Path $currentDir -Parent
            } catch {
                break
            }
        } else {
            break
        }
    }
}

function Get-RelativePath {
    param(
        [Parameter(Mandatory)]
        [string]$BasePath,

        [Parameter(Mandatory)]
        [string]$FullPath
    )

    $base = [System.IO.Path]::GetFullPath($BasePath).TrimEnd('\') + '\'
    $full = [System.IO.Path]::GetFullPath($FullPath)

    if ($full.StartsWith($base, [System.StringComparison]::OrdinalIgnoreCase)) {
        return $full.Substring($base.Length)
    }

    return $full
}

function Get-FileSignature {
    param(
        [Parameter(Mandatory)]
        [System.IO.FileInfo]$File
    )

    $lastWriteUtc = $File.LastWriteTimeUtc.ToString("o")
    $creationUtc = $File.CreationTimeUtc.ToString("o")
    $hash = (Get-FileHash -LiteralPath $File.FullName -Algorithm SHA256).Hash

    [pscustomobject]@{
        SizeBytes    = [int64]$File.Length
        LastWriteUtc = $lastWriteUtc
        CreationUtc  = $creationUtc
        Hash         = $hash
    }
}

function Load-State {
    if (-not (Test-Path -LiteralPath $StatePath)) {
        return @{}
    }

    $raw = Get-Content -LiteralPath $StatePath -Raw
    if ([string]::IsNullOrWhiteSpace($raw)) {
        return @{}
    }

    $obj = $raw | ConvertFrom-Json
    $state = @{}

    foreach ($prop in $obj.PSObject.Properties) {
        $state[$prop.Name] = $prop.Value
    }

    return $state
}

function Save-State {
    param(
        [Parameter(Mandatory)]
        [hashtable]$State
    )

    $ordered = [ordered]@{}
    foreach ($key in ($State.Keys | Sort-Object)) {
        $ordered[$key] = $State[$key]
    }

    $tempPath = $StatePath + ".tmp"
    $ordered | ConvertTo-Json -Depth 10 | Set-Content -LiteralPath $tempPath -Encoding UTF8
    Move-Item -LiteralPath $tempPath -Destination $StatePath -Force
}

function Write-JsonlLog {
    param(
        [Parameter(Mandatory)]
        [hashtable]$Entry
    )

    $line = ($Entry | ConvertTo-Json -Depth 20 -Compress)
    Add-Content -LiteralPath $JsonlLogPath -Value $line -Encoding UTF8
}

function Write-SummaryCsv {
    param(
        [Parameter(Mandatory)]
        [hashtable]$Entry
    )

    $summary = [pscustomobject]@{
        TimestampUtc   = $Entry.TimestampUtc
        RelativePath   = $Entry.RelativePath
        Stage          = $Entry.Stage
        Outcome        = $Entry.Outcome
        Attempt        = $Entry.Attempt
        SizeBytes      = $Entry.SizeBytes
        LastWriteUtc   = $Entry.LastWriteUtc
        CreationUtc    = $Entry.CreationUtc
        Hash           = $Entry.Hash
        FileId         = $Entry.FileId
        HttpStatusCode = $Entry.HttpStatusCode
        RemoteStatus   = $Entry.RemoteStatus
        Message        = $Entry.Message
        Error          = $Entry.Error
    }

    if (-not (Test-Path -LiteralPath $SummaryCsvPath)) {
        $summary | Export-Csv -LiteralPath $SummaryCsvPath -NoTypeInformation -Encoding UTF8
    } else {
        $summary | Export-Csv -LiteralPath $SummaryCsvPath -NoTypeInformation -Append -Encoding UTF8
    }
}

function Write-LogEntry {
    param(
        [Parameter(Mandatory)]
        [string]$RelativePath,

        [Parameter(Mandatory)]
        [string]$Stage,

        [Parameter(Mandatory)]
        [string]$Outcome,

        [int]$Attempt = 0,

        [Nullable[int]]$HttpStatusCode = $null,

        [string]$Message = "",

        [string]$Error = "",

        [string]$FileId = "",

        [string]$RemoteStatus = "",

        [string]$UploadResponseRaw = "",

        [string]$ProcessingStatusRaw = "",

        [string]$KnowledgeResponseRaw = "",

        [Int64]$SizeBytes = 0,

        [string]$LastWriteUtc = "",
        
        [string]$CreationUtc = "",

        [string]$Hash = ""
    )

    $entry = [ordered]@{
        TimestampUtc        = (Get-Date).ToUniversalTime().ToString("o")
        RelativePath        = $RelativePath
        Stage               = $Stage
        Outcome             = $Outcome
        Attempt             = $Attempt
        HttpStatusCode      = $HttpStatusCode
        Message             = $Message
        Error               = $Error
        FileId              = $FileId
        RemoteStatus        = $RemoteStatus
        SizeBytes           = $SizeBytes
        LastWriteUtc        = $LastWriteUtc
        CreationUtc         = $CreationUtc
        Hash                = $Hash
        UploadResponseRaw   = $UploadResponseRaw
        ProcessingStatusRaw = $ProcessingStatusRaw
        KnowledgeResponseRaw = $KnowledgeResponseRaw
    }

    Write-JsonlLog -Entry $entry
    Write-SummaryCsv -Entry $entry
}

function Write-ErrorLog {
    param(
        [Parameter(Mandatory)]
        [string]$RelativePath,

        [Parameter(Mandatory)]
        [string]$ErrorMessage,

        [string]$Details = ""
    )
    $timestamp = (Get-Date).ToUniversalTime().ToString("o")
    $logLine = "[$timestamp] FILE: $RelativePath `r`nERROR: $ErrorMessage"
    if (-not [string]::IsNullOrWhiteSpace($Details)) {
        $logLine += "`r`nTRACE: $Details"
    }
    $logLine += "`r`n---------------------------------------------------"
    Add-Content -LiteralPath $ErrorLogPath -Value $logLine -Encoding UTF8
}

function Invoke-UploadFile {
    param(
        [Parameter(Mandatory)]
        [string]$FilePath
    )

    $url = "$OpenWebUIBaseUrl/api/v1/files/"
    
    try {
        $form = @{ file = Get-Item -LiteralPath $FilePath }
        $response = Invoke-RestMethod -Uri $url -Method Post -Headers $ApiHeaders -Form $form -SkipHttpErrorCheck -StatusCodeVariable httpCode
        
        # Convert response object back to string to perfectly match existing Try-ParseJson logic
        $bodyStr = if ($response) { $response | ConvertTo-Json -Depth 10 -Compress } else { "{}" }

        [pscustomobject]@{
            StatusCode = [int]$httpCode
            Success    = ($httpCode -ge 200 -and $httpCode -lt 300)
            Body       = $bodyStr
        }
    }
    catch {
        throw $_
    }
}

function Invoke-GetProcessingStatus {
    param(
        [Parameter(Mandatory)]
        [string]$FileId
    )

    $url = "$OpenWebUIBaseUrl/api/v1/files/$FileId/process/status"
    
    try {
        $response = Invoke-RestMethod -Uri $url -Method Get -Headers $ApiHeaders -SkipHttpErrorCheck -StatusCodeVariable httpCode
        $bodyStr = if ($response) { $response | ConvertTo-Json -Depth 10 -Compress } else { "{}" }

        [pscustomobject]@{
            StatusCode = [int]$httpCode
            Success    = ($httpCode -ge 200 -and $httpCode -lt 300)
            Body       = $bodyStr
        }
    }
    catch {
        throw $_
    }
}

function Invoke-AddFileToKnowledge {
    param(
        [Parameter(Mandatory)]
        [string]$FileId
    )

    $url = "$OpenWebUIBaseUrl/api/v1/knowledge/$KnowledgeId/file/add"
    $payload = @{ file_id = $FileId } | ConvertTo-Json -Compress
    
    try {
        $response = Invoke-RestMethod -Uri $url -Method Post -Headers $ApiHeaders -Body $payload -ContentType "application/json" -SkipHttpErrorCheck -StatusCodeVariable httpCode
        $bodyStr = if ($response) { $response | ConvertTo-Json -Depth 10 -Compress } else { "{}" }

        [pscustomobject]@{
            StatusCode = [int]$httpCode
            Success    = ($httpCode -ge 200 -and $httpCode -lt 300)
            Body       = $bodyStr
        }
    }
    catch {
        throw $_
    }
}

function Try-ParseJson {
    param([string]$Text)

    if ([string]::IsNullOrWhiteSpace($Text)) { return $null }

    try {
        return $Text | ConvertFrom-Json
    }
    catch {
        return $null
    }
}

function Get-FileList {
    param(
        [Parameter(Mandatory)]
        [string]$Path
    )

    $gciParams = @{
        LiteralPath = $Path
        Recurse     = $true
        File        = $true
        ErrorAction = 'Stop'
    }

    if ($IncludeHiddenFiles) {
        $gciParams.Force = $true
    }

    Get-ChildItem @gciParams
}

function Get-SafeProperty {
    param(
        [Parameter(Mandatory=$false)]
        [psobject]$Object,

        [Parameter(Mandatory=$true)]
        [string]$PropertyName
    )
    if ($null -eq $Object) { return $null }
    
    # Strict-mode safe check for property existence
    $propFound = $Object.PSObject.Properties | Where-Object { $_.Name -eq $PropertyName }
    if ($null -ne $propFound) {
        return $propFound.Value
    }
    return $null
}

# ------------------------------
# VALIDATION & SETUP
# ------------------------------
Write-Host "Initializing OpenWebUI Knowledge Sync (PowerShell 7)..." -ForegroundColor Cyan
Write-Host "Scanning directory: $RootPath" -ForegroundColor DarkGray

$state = Load-State

# Coerce to array so we can count it properly
$files = @(Get-FileList -Path $RootPath) 
$totalFilesCount = $files.Count
$currentIndex = 0

$processedFiles = 0
$skippedFiles = 0
$failedFiles = 0
$successFiles = 0
$junkFilesMoved = 0

Write-Host "Found $totalFilesCount files to evaluate." -ForegroundColor Cyan
Write-Host "---------------------------------------------------"

:FileLoop
foreach ($file in $files) {
    $currentIndex++

    # Calculate percentage for progress bar
    $percent = 0
    if ($totalFilesCount -gt 0) {
        $percent = [math]::Floor(($currentIndex / $totalFilesCount) * 100)
    }

    $relativePath = Get-RelativePath -BasePath $RootPath -FullPath $file.FullName

    # MASTER TRY/CATCH: Prevents any single file error from halting the entire script
    try {
        $ext = $file.Extension.ToLowerInvariant()

        # ---------------------------------------------------------
        # SIZE FILTER LOGIC
        # ---------------------------------------------------------
        if ($file.Length -lt $MinSizeBytes) {
            $skippedFiles++
            Write-Host "[SKIP]     $relativePath (Too small: $($file.Length) bytes)" -ForegroundColor DarkGray
            continue FileLoop
        }

        # ---------------------------------------------------------
        # JUNK MOVER LOGIC
        # ---------------------------------------------------------
        if ($IncludeExtensions.Count -gt 0 -and ($IncludeExtensions -notcontains $ext)) {
            $skippedFiles++
            
            $junkDestDir = Join-Path $JunkPath (Split-Path $relativePath -Parent)
            if (-not (Test-Path -LiteralPath $junkDestDir)) {
                $null = New-Item -ItemType Directory -Path $junkDestDir -Force
            }
            $junkDestFile = Join-Path $junkDestDir $file.Name

            Write-Host "[JUNK]     $relativePath (Unsupported format moved)" -ForegroundColor DarkMagenta
            
            try {
                Move-Item -LiteralPath $file.FullName -Destination $junkDestFile -Force
                $junkFilesMoved++
                
                # Dynamic empty directory cleanup
                Remove-EmptyDirectoryTree -DirectoryPath $file.DirectoryName -RootLimitPath $RootPath
            } catch {
                Write-Host " -> FAILED TO MOVE" -ForegroundColor Red
                Write-ErrorLog -RelativePath $relativePath -ErrorMessage "Failed to move junk file: $($_.Exception.Message)"
            }
            continue FileLoop
        }

        if ($ExcludeExtensions -contains $ext) {
            continue FileLoop
        }

        $signature = Get-FileSignature -File $file
        $safeHash = $signature.Hash

        Write-Progress -Activity "Syncing Knowledge to OpenWebUI" -Status "File $currentIndex of ${totalFilesCount}: $relativePath" -PercentComplete $percent

        $existing = $null
        if ($state.ContainsKey($relativePath)) {
            $existing = $state[$relativePath]
        }

        # ---------------------------------------------------------
        # PS7 DATE PARSING FIX
        # ---------------------------------------------------------
        $sameSignature = $false
        if ($null -ne $existing) {
            $stateDateStr = $existing.LastWriteUtc
            
            # If PS7 parsed the JSON date into a DateTime object, convert it back to match our signature format
            if ($stateDateStr -is [datetime]) {
                $stateDateStr = $stateDateStr.ToUniversalTime().ToString("o")
            } else {
                $stateDateStr = [string]$stateDateStr
            }

            $sameSignature = ($existing.SizeBytes -eq $signature.SizeBytes -and $stateDateStr -eq $signature.LastWriteUtc -and [string]$existing.Hash -eq [string]$signature.Hash)
        }

        if ($sameSignature -and $existing.Status -eq 'Added') {
            $skippedFiles++
            
            $logFileId = ""
            if ($null -ne $existing.FileId) { $logFileId = $existing.FileId }

            Write-Host "[SKIP]     $relativePath (Unchanged)" -ForegroundColor DarkGray
            Write-LogEntry `
                -RelativePath $relativePath `
                -Stage 'Skip' `
                -Outcome 'SkippedUnchanged' `
                -Message 'File unchanged and already added to knowledge.' `
                -FileId $logFileId `
                -SizeBytes $signature.SizeBytes `
                -LastWriteUtc $signature.LastWriteUtc `
                -CreationUtc $signature.CreationUtc `
                -Hash $safeHash
            continue FileLoop
        }

        $processedFiles++
        $reuseExistingFileId = $false
        $fileId = $null

        if ($sameSignature -and ($null -ne $existing.FileId) -and ($existing.Status -in @('Uploaded', 'Processed', 'Processing', 'AddFailed'))) {
            $reuseExistingFileId = $true
            $fileId = $existing.FileId
            
            $logFileId = ""
            if ($null -ne $fileId) { $logFileId = $fileId }

            Write-Host "[RESUME]   $relativePath (Previous upload found)" -ForegroundColor Yellow
            Write-LogEntry `
                -RelativePath $relativePath `
                -Stage 'Resume' `
                -Outcome 'ReusingExistingFileId' `
                -Message 'Signature matched; resuming from prior file ID.' `
                -FileId $logFileId `
                -SizeBytes $signature.SizeBytes `
                -LastWriteUtc $signature.LastWriteUtc `
                -CreationUtc $signature.CreationUtc `
                -Hash $safeHash
        }

        if (-not $reuseExistingFileId) {
            $uploadSuccess = $false
            $uploadResponse = $null

            Write-Host "[UPLOAD]   $relativePath " -ForegroundColor Cyan -NoNewline

            for ($attempt = 1; $attempt -le $MaxRetries; $attempt++) {
                try {
                    $uploadResponse = Invoke-UploadFile -FilePath $file.FullName
                    $uploadBody = $uploadResponse.Body
                    $uploadJson = Try-ParseJson -Text $uploadBody
                    
                    $uploadId = Get-SafeProperty -Object $uploadJson -PropertyName "id"

                    if ($uploadResponse.Success -and ($null -ne $uploadId)) {
                        $fileId = [string]$uploadId
                        $uploadSuccess = $true

                        Write-Host "-> OK " -ForegroundColor Green

                        Write-LogEntry `
                            -RelativePath $relativePath `
                            -Stage 'Upload' `
                            -Outcome 'Success' `
                            -Attempt $attempt `
                            -HttpStatusCode $uploadResponse.StatusCode `
                            -Message 'File uploaded successfully.' `
                            -FileId $fileId `
                            -UploadResponseRaw $uploadBody `
                            -SizeBytes $signature.SizeBytes `
                            -LastWriteUtc $signature.LastWriteUtc `
                            -CreationUtc $signature.CreationUtc `
                            -Hash $safeHash

                        break
                    }
                    else {
                        Write-LogEntry `
                            -RelativePath $relativePath `
                            -Stage 'Upload' `
                            -Outcome 'Failed' `
                            -Attempt $attempt `
                            -HttpStatusCode $uploadResponse.StatusCode `
                            -Message 'Upload returned non-success or did not include file id.' `
                            -Error $uploadBody `
                            -UploadResponseRaw $uploadBody `
                            -SizeBytes $signature.SizeBytes `
                            -LastWriteUtc $signature.LastWriteUtc `
                            -CreationUtc $signature.CreationUtc `
                            -Hash $safeHash
                    }
                }
                catch {
                    Write-LogEntry `
                        -RelativePath $relativePath `
                        -Stage 'Upload' `
                        -Outcome 'Failed' `
                        -Attempt $attempt `
                        -Message 'Upload threw an exception.' `
                        -Error $_.Exception.Message `
                        -SizeBytes $signature.SizeBytes `
                        -LastWriteUtc $signature.LastWriteUtc `
                        -CreationUtc $signature.CreationUtc `
                        -Hash $safeHash
                }

                if ($attempt -lt $MaxRetries) {
                    Write-Host "." -ForegroundColor Yellow -NoNewline
                    Start-Sleep -Seconds $RetryDelaySeconds
                }
            }

            if (-not $uploadSuccess) {
                Write-Host "-> FAILED" -ForegroundColor Red
                $failedFiles++
                $state[$relativePath] = [ordered]@{
                    RelativePath  = $relativePath
                    FullPath      = $file.FullName
                    SizeBytes     = $signature.SizeBytes
                    LastWriteUtc  = $signature.LastWriteUtc
                    CreationUtc   = $signature.CreationUtc
                    Hash          = $signature.Hash
                    Status        = 'UploadFailed'
                    FileId        = $null
                    Attempts      = $MaxRetries
                    LastUpdatedUtc = (Get-Date).ToUniversalTime().ToString("o")
                    LastError     = 'Upload failed after retries.'
                }
                Save-State -State $state
                continue FileLoop
            }
        }

        $processingSucceeded = $false
        $processStart = Get-Date

        Write-Host "  [PROCESS] Waiting for OpenWebUI to vectorize..." -ForegroundColor DarkCyan -NoNewline

        while (((Get-Date) - $processStart).TotalSeconds -lt $ProcessTimeoutSeconds) {
            try {
                $statusResponse = Invoke-GetProcessingStatus -FileId $fileId
                $statusBody = $statusResponse.Body
                $statusJson = Try-ParseJson -Text $statusBody

                $remoteStatus = ""
                $remoteError = ""
                
                if ($null -ne $statusJson) {
                    $statusVal = Get-SafeProperty -Object $statusJson -PropertyName "status"
                    if ($null -ne $statusVal) { $remoteStatus = [string]$statusVal }
                    
                    $errorVal = Get-SafeProperty -Object $statusJson -PropertyName "error"
                    if ($null -ne $errorVal) { $remoteError = [string]$errorVal }
                }

                Write-LogEntry `
                    -RelativePath $relativePath `
                    -Stage 'ProcessingStatus' `
                    -Outcome 'Checked' `
                    -HttpStatusCode $statusResponse.StatusCode `
                    -FileId $fileId `
                    -RemoteStatus $remoteStatus `
                    -ProcessingStatusRaw $statusBody `
                    -Message 'Polled processing status.' `
                    -SizeBytes $signature.SizeBytes `
                    -LastWriteUtc $signature.LastWriteUtc `
                    -CreationUtc $signature.CreationUtc `
                    -Hash $safeHash

                if ($remoteStatus -eq 'completed') {
                    $processingSucceeded = $true
                    Write-Host "-> OK " -ForegroundColor Green
                    break
                }
                elseif ($remoteStatus -eq 'failed') {
                    $displayError = $statusBody
                    if ($remoteError -ne "") { $displayError = $remoteError }

                    Write-Host "-> FAILED ($displayError)" -ForegroundColor Red
                    $failedFiles++
                    
                    Write-LogEntry `
                        -RelativePath $relativePath `
                        -Stage 'ProcessingStatus' `
                        -Outcome 'Failed' `
                        -FileId $fileId `
                        -RemoteStatus 'failed' `
                        -Message 'OpenWebUI reported processing failure.' `
                        -Error $displayError `
                        -ProcessingStatusRaw $statusBody `
                        -SizeBytes $signature.SizeBytes `
                        -LastWriteUtc $signature.LastWriteUtc `
                        -CreationUtc $signature.CreationUtc `
                        -Hash $safeHash

                    $state[$relativePath] = [ordered]@{
                        RelativePath   = $relativePath
                        FullPath       = $file.FullName
                        SizeBytes      = $signature.SizeBytes
                        LastWriteUtc   = $signature.LastWriteUtc
                        CreationUtc    = $signature.CreationUtc
                        Hash           = $signature.Hash
                        Status         = 'ProcessingFailed'
                        FileId         = $fileId
                        Attempts       = 1
                        LastUpdatedUtc = (Get-Date).ToUniversalTime().ToString("o")
                        LastError      = $displayError
                    }
                    Save-State -State $state
                    continue FileLoop
                }
            }
            catch {
                Write-LogEntry `
                    -RelativePath $relativePath `
                    -Stage 'ProcessingStatus' `
                    -Outcome 'Failed' `
                    -FileId $fileId `
                    -Message 'Status polling threw an exception.' `
                    -Error $_.Exception.Message `
                    -SizeBytes $signature.SizeBytes `
                    -LastWriteUtc $signature.LastWriteUtc `
                    -CreationUtc $signature.CreationUtc `
                    -Hash $safeHash
            }

            Write-Host "." -ForegroundColor DarkGray -NoNewline
            Start-Sleep -Seconds $PollIntervalSeconds
        }

        if (-not $processingSucceeded) {
            Write-Host "-> TIMEOUT" -ForegroundColor Red
            $failedFiles++
            Write-LogEntry `
                -RelativePath $relativePath `
                -Stage 'ProcessingStatus' `
                -Outcome 'Timeout' `
                -FileId $fileId `
                -Message "Processing did not complete within $ProcessTimeoutSeconds seconds." `
                -SizeBytes $signature.SizeBytes `
                -LastWriteUtc $signature.LastWriteUtc `
                -CreationUtc $signature.CreationUtc `
                -Hash $safeHash

            $state[$relativePath] = [ordered]@{
                RelativePath   = $relativePath
                FullPath       = $file.FullName
                SizeBytes      = $signature.SizeBytes
                LastWriteUtc   = $signature.LastWriteUtc
                CreationUtc    = $signature.CreationUtc
                Hash           = $signature.Hash
                Status         = 'ProcessingTimeout'
                FileId         = $fileId
                Attempts       = 1
                LastUpdatedUtc = (Get-Date).ToUniversalTime().ToString("o")
                LastError      = "Processing timed out."
            }
            Save-State -State $state
            continue FileLoop
        }

        Write-Host "  [ADD]      Linking to knowledge collection..." -ForegroundColor Magenta -NoNewline
        $addSuccess = $false
        for ($attempt = 1; $attempt -le $MaxRetries; $attempt++) {
            try {
                $addResponse = Invoke-AddFileToKnowledge -FileId $fileId
                $addBody = $addResponse.Body
                
                $isDuplicate = ($addResponse.StatusCode -eq 400 -and $addBody -like "*Duplicate content detected*")

                if ($addResponse.Success -or $isDuplicate) {
                    $addSuccess = $true
                    
                    if ($isDuplicate) {
                        Write-Host "-> ALREADY EXISTS (OK)" -ForegroundColor Yellow
                    } else {
                        Write-Host "-> SUCCESS" -ForegroundColor Green
                    }

                    Write-LogEntry `
                        -RelativePath $relativePath `
                        -Stage 'KnowledgeAdd' `
                        -Outcome 'Success' `
                        -Attempt $attempt `
                        -HttpStatusCode $addResponse.StatusCode `
                        -FileId $fileId `
                        -Message 'File added to knowledge successfully.' `
                        -KnowledgeResponseRaw $addBody `
                        -SizeBytes $signature.SizeBytes `
                        -LastWriteUtc $signature.LastWriteUtc `
                        -CreationUtc $signature.CreationUtc `
                        -Hash $safeHash
                    break
                }
                else {
                    Write-LogEntry `
                        -RelativePath $relativePath `
                        -Stage 'KnowledgeAdd' `
                        -Outcome 'Failed' `
                        -Attempt $attempt `
                        -HttpStatusCode $addResponse.StatusCode `
                        -FileId $fileId `
                        -Message 'Knowledge add returned non-success.' `
                        -Error $addBody `
                        -KnowledgeResponseRaw $addBody `
                        -SizeBytes $signature.SizeBytes `
                        -LastWriteUtc $signature.LastWriteUtc `
                        -CreationUtc $signature.CreationUtc `
                        -Hash $safeHash
                }
            }
            catch {
                Write-LogEntry `
                    -RelativePath $relativePath `
                    -Stage 'KnowledgeAdd' `
                    -Outcome 'Failed' `
                    -Attempt $attempt `
                    -FileId $fileId `
                    -Message 'Knowledge add threw an exception.' `
                    -Error $_.Exception.Message `
                    -SizeBytes $signature.SizeBytes `
                    -LastWriteUtc $signature.LastWriteUtc `
                    -CreationUtc $signature.CreationUtc `
                    -Hash $safeHash
            }

            if ($attempt -lt $MaxRetries) {
                Write-Host "." -ForegroundColor Magenta -NoNewline
                Start-Sleep -Seconds $RetryDelaySeconds
            }
        }

        if ($addSuccess) {
            $successFiles++
            $state[$relativePath] = [ordered]@{
                RelativePath   = $relativePath
                FullPath       = $file.FullName
                SizeBytes      = $signature.SizeBytes
                LastWriteUtc   = $signature.LastWriteUtc
                CreationUtc    = $signature.CreationUtc
                Hash           = $signature.Hash
                Status         = 'Added'
                FileId         = $fileId
                Attempts       = 1
                LastUpdatedUtc = (Get-Date).ToUniversalTime().ToString("o")
                LastError      = $null
            }
            Save-State -State $state

            # Post-Success File Deletion
            try {
                Remove-Item -LiteralPath $file.FullName -Force
                Write-Host "  [CLEANUP]  File deleted successfully." -ForegroundColor DarkGray
                
                # Dynamic empty directory cleanup
                Remove-EmptyDirectoryTree -DirectoryPath $file.DirectoryName -RootLimitPath $RootPath
            }
            catch {
                Write-Host "  [CLEANUP]  FAILED TO DELETE" -ForegroundColor Red
                Write-ErrorLog -RelativePath $relativePath -ErrorMessage "Failed to delete file after successful knowledge add: $($_.Exception.Message)"
            }
        }
        else {
            Write-Host " -> FAILED" -ForegroundColor Red
            $failedFiles++
            $state[$relativePath] = [ordered]@{
                RelativePath   = $relativePath
                FullPath       = $file.FullName
                SizeBytes      = $signature.SizeBytes
                LastWriteUtc   = $signature.LastWriteUtc
                CreationUtc    = $signature.CreationUtc
                Hash           = $signature.Hash
                Status         = 'AddFailed'
                FileId         = $fileId
                Attempts       = $MaxRetries
                LastUpdatedUtc = (Get-Date).ToUniversalTime().ToString("o")
                LastError      = 'Failed to add to knowledge after retries.'
            }
            Save-State -State $state
        }
    }
    catch {
        # Catch-all for any unforeseen fatal errors during file processing
        Write-Host " -> FATAL EXCEPTION ENCOUNTERED" -ForegroundColor Red
        Write-ErrorLog -RelativePath $relativePath -ErrorMessage $_.Exception.Message -Details $_.ScriptStackTrace
        $failedFiles++
        continue FileLoop
    }
}

Write-Progress -Activity "Syncing Knowledge to OpenWebUI" -Completed

Save-State -State $state

Write-Host ""
Write-Host "===================================================" -ForegroundColor Cyan
Write-Host "SYNC COMPLETE" -ForegroundColor Green
Write-Host "===================================================" -ForegroundColor Cyan
Write-Host "Total files evaluated : $totalFilesCount"
Write-Host "Moved to Junk         : $junkFilesMoved" -ForegroundColor DarkMagenta
Write-Host "Skipped (Unchanged)   : $skippedFiles" -ForegroundColor DarkGray
Write-Host "Processed (New/Mod)   : $processedFiles"
Write-Host "Successfully Added    : $successFiles" -ForegroundColor Green
if ($failedFiles -gt 0) {
    Write-Host "Failed                : $failedFiles" -ForegroundColor Red
} else {
    Write-Host "Failed                : $failedFiles"
}
Write-Host "---------------------------------------------------"
Write-Host "Logs:"
Write-Host "  $JsonlLogPath"
Write-Host "  $SummaryCsvPath"
Write-Host "  $ErrorLogPath"
Write-Host "State:"
Write-Host "  $StatePath"
Write-Host ""
